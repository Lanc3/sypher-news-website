# --- Required for admin login (NextAuth v5) ---
# Prefer these names on Vercel:
AUTH_SECRET="paste-a-long-random-string-here"
AUTH_URL="https://your-project.vercel.app"
#
# If you already use the old names, they still work (see auth.ts):
# NEXTAUTH_SECRET → used as AUTH_SECRET when AUTH_SECRET is empty
# NEXTAUTH_URL    → used as AUTH_URL when AUTH_URL is empty
#
# On Vercel only: if AUTH_URL is still unset, we fall back to https://$VERCEL_URL (auto env).

DATABASE_URL="postgresql://user:pass@localhost:5432/sypher_news_site?schema=public"

NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="same-as-AUTH_SECRET-for-local"

# Shared secret for POST /api/v1/articles, POST /api/sypher/articles, and GET /api/health (Bearer or X-Api-Key).
ARTICLES_INGEST_API_KEY="long-random-api-key"
# Optional: Sypher Sync can use SYPHER_INGEST_TOKEN for POST /api/sypher/articles; if unset, that route uses ARTICLES_INGEST_API_KEY.
# SYPHER_INGEST_TOKEN="same-as-ingest-or-different"
NEXT_PUBLIC_SITE_URL="http://localhost:3002"
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-xxxxxxxxxxxxxxxx"
ADMIN_SEED_PASSWORD="changeme"

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: Resend Audience sync for newsletter lifecycle.
RESEND_API_KEY=""
RESEND_AUDIENCE_ID=""
